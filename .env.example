# Kopiere diese Datei zu ".env" und trage deine Werte ein.

# Port, auf dem die App läuft
PORT=3000

# Öffentliche Basis-URL (wichtig für die Links in den E-Mails!)
# Lokal:   http://localhost:3000
# Online:  https://deine-app.onrender.com   (o.ä.)
BASE_URL=http://localhost:3000

# ---- E-Mail-Versand (SMTP) ----
# Ohne diese Werte läuft die App im DRY-RUN: Mails werden nur ins Server-Log
# geschrieben (praktisch zum Testen). Für echten Versand alles ausfüllen.

# Beispiel Gmail (App-Passwort nötig, NICHT dein normales Passwort!):
#   1. Google-Konto -> Sicherheit -> 2-Faktor aktivieren
#   2. "App-Passwörter" -> neues Passwort generieren -> hier eintragen
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=deine.adresse@gmail.com
SMTP_PASS=dein-app-passwort

# WICHTIG gegen Spam-Einstufung: MAIL_FROM sollte zur SMTP_HOST-Domain passen
# (z.B. nicht @gmail.com senden, wenn über einen anderen Provider verschickt wird).
# Siehe README "E-Mails landen im Spam" für SPF/DKIM/DMARC-Hinweise.
MAIL_FROM=Shirt-Tausch <deine.adresse@gmail.com>
